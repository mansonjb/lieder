# --- Site ---------------------------------------------------------------
# Domaine canonique (sans slash final). Sert aux metadata, sitemap, JSON-LD, hreflang.
NEXT_PUBLIC_SITE_URL=https://exploreiledere.com

# (optionnel) Nom de marque affiche. Defaut : "Explore Île de Ré".
NEXT_PUBLIC_SITE_NAME=Explore Île de Ré

# --- Stay22 (affiliation hebergement) -----------------------------------
# Script LetMeAllez (LMA) : reecrit les liens de reservation sortants en liens
# affilies. C'est l'integration principale. ID visible dans hub.stay22.com.
NEXT_PUBLIC_STAY22_LMA_ID=

# Partner ID (aid) de la carte embarquee (iframe stay22.com/embed/gm).
# Souvent identique au lmaID ; a confirmer dans hub.stay22.com (Partner ID).
# NE JAMAIS commiter la vraie valeur : la mettre dans .env.local
STAY22_AID=
